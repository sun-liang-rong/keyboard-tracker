{
  "name": "keyboard-tracker",
  "version": "1.0.0",
  "description": "键盘活跃度统计工具 - KeyboardTracker",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:mac": "vue-tsc --noEmit && vite build && electron-builder --mac",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "preview": "vite preview"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "lowdb": "^7.0.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^13.0.0",
    "autoprefixer": "^10.4.19",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.7"
  },
  "build": {
    "appId": "com.keyboardtracker.app",
    "productName": "KeyboardTracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
